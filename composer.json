{
  "name": "pig/router",
  "description": "A simple and lightweight PHP routing library",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "sn01615"
    }
  ],
  "keywords": ["router", "routing", "php", "middleware", "http"],
  "require": {
    "php": ">=5.6.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^5.7|^6.0|^7.0|^8.0|^9.0|^10.0"
  },
  "autoload": {
    "psr-4": {
      "Pig\\Router\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
